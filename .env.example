# ===== Slow SQL Analyzer V5.0 统一配置 =====
# 复制此文件为 .env 并修改实际值

# MySQL 平台库（诊断记录/RAG/采集记录）
MYSQL_URL=jdbc:mysql://localhost:3306/slow_sql_platform?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=root
MYSQL_PASSWORD=123456

# MySQL 实例（被监控的业务库）
INSTANCE_HOST=localhost
INSTANCE_PORT=3306
INSTANCE_USERNAME=root
INSTANCE_PASSWORD=123456
INSTANCE_DATABASE=test_sql

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=2

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_MGMT_PORT=15672

# 内部安全令牌（Java Gateway ↔ Python Agent）
INTERNAL_TOKEN=slow-sql-internal-token-v5

# Jasypt 加密
JASYPT_ENCRYPTOR_PASSWORD=

# Python Agent
AGENT_PORT=8000
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Java Gateway
GATEWAY_PORT=8080

# Vue 前端
FRONTEND_PORT=5173
